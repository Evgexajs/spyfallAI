# SpyfallAI Environment Configuration

# Required: OpenAI API Key
OPENAI_API_KEY=

# Game Settings (all have sensible defaults)
PLAYERS_PER_GAME=4
GAME_DURATION_MINUTES=5
MAX_QUESTIONS_BEFORE_VOTE=30
SPY_CONFIDENCE_CHECK_EVERY_N=3
MAX_PARTY_COST_USD=3.0

# Speech delay (seconds per character)
SPEECH_DELAY_MULTIPLIER=0.03

# Context compression (to save tokens on long games)
CONTEXT_COMPRESSION_AFTER_N_TURNS=10
CONTEXT_KEEP_LAST_K_TURNS=6

# Defense phase settings (CR-001: two-stage voting with defense speeches)
# Minimum votes on a player to trigger defense speech phase
DEFENSE_MIN_VOTES_TO_QUALIFY=2
# Maximum sentences allowed in a defense speech (longer will be truncated)
DEFENSE_SPEECH_MAX_SENTENCES=2
# Whether abstaining (not voting) is allowed in preliminary vote (true/false)
DEFENSE_ALLOW_ABSTAIN=true

# Trigger detector settings (CR-002: new trigger condition types)
# Window size (in turns) for counting repeated accusations on same target
REPEATED_ACCUSATION_WINDOW=5
# Window size (in turns) for contradiction detection history
CONTRADICTION_HISTORY_WINDOW=10

# Post-game analysis settings (CR-003: automated character analysis after game)
# Whether to auto-run analyzer after each game (true/false)
POST_GAME_ANALYSIS_ENABLED=true
# Timeout in seconds for each LLM call during analysis
POST_GAME_ANALYSIS_TIMEOUT_SECONDS=30
# LLM role from llm_config.json to use for analysis (main/utility)
POST_GAME_ANALYSIS_MODEL_ROLE=utility

# Web UI
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=8000
