# SpyfallAI Environment Configuration

# Required: OpenAI API Key
OPENAI_API_KEY=

# Optional: Anthropic API Key (for alternative provider)
ANTHROPIC_API_KEY=

# Game Configuration
GAME_DURATION_MINUTES=3
PLAYERS_PER_GAME=4
MAX_QUESTIONS_BEFORE_VOTE=50
SPEECH_DELAY_MULTIPLIER=0.03
SPY_CONFIDENCE_CHECK_EVERY_N=3
MAX_PARTY_COST_USD=3.0

# Context Compression
CONTEXT_COMPRESSION_AFTER_N_TURNS=10
CONTEXT_KEEP_LAST_K_TURNS=6

# Logging
LOG_LEVEL=INFO

# Web UI
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=8000
