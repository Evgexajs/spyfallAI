{
  "description": "Global trigger rules for SpyfallAI - applied to all characters",
  "version": "1.0",
  "global_triggers": [
    {
      "id": "global_direct_accusation",
      "condition_type": "direct_accusation",
      "description": "Triggers when a character is directly accused by name",
      "priority": 5,
      "threshold": 0.5,
      "default_reaction_type": "deflect_suspicion_to_another",
      "detection": {
        "method": "markers",
        "accusation_patterns": [
          "\\bшпион\\b",
          "\\bврёшь\\b",
          "\\bврет\\b",
          "\\bлжёшь\\b",
          "\\bлжец\\b",
          "\\bобманываешь\\b",
          "\\bподозрительн",
          "\\bвиноват",
          "\\bэто ты\\b",
          "\\bты и есть\\b",
          "\\bименно ты\\b",
          "\\bточно ты\\b",
          "\\bне верю тебе\\b",
          "\\bне доверяю\\b"
        ]
      }
    },
    {
      "id": "global_silent_for_n_turns",
      "condition_type": "silent_for_n_turns",
      "description": "[DEPRECATED] Резервный триггер молчания. Используйте персональные триггеры silent_for_n_turns из профилей персонажей (TASK-068). Этот глобальный триггер сохранён для обратной совместимости, но не используется системой.",
      "deprecated": true,
      "priority": 3,
      "threshold": 0.7,
      "default_reaction_type": "point_out_inconsistency",
      "params": {
        "silent_turns": 3
      },
      "detection": {
        "method": "counter",
        "rule": "turns_since_spoke >= silent_turns"
      }
    },
    {
      "id": "global_repeated_accusation",
      "condition_type": "repeated_accusation_on_same_target",
      "description": "Triggers when the same player is accused 2+ times within a window of turns",
      "priority": 4,
      "threshold": 0.5,
      "default_reaction_type": "deflect_suspicion_to_another",
      "params": {
        "window": 5
      },
      "detection": {
        "method": "counter_with_markers",
        "rule": "accusations_on_target >= 2 within window turns"
      }
    }
  ],
  "accusation_markers": {
    "description": "Markers that indicate accusation intent - used by direct_accusation detection",
    "strong_markers": ["шпион", "врёшь", "врет", "лжёшь", "лжец", "виноват"],
    "weak_markers": ["подозрительно", "странно ведёшь", "не верю", "скрываешь"]
  }
}
