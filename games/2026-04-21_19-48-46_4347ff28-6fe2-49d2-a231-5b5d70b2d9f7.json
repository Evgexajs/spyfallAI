      "display_delay_ms": 3198,
      "raw_response": "{\n  \"content\": \"Штейн, скажи, а какие звуки ты слышишь чаще всего, ну в смысле, в основном здесь слышны?\",\n  \"wants_vote\": false,\n  \"suspect_id\": null\n}"
